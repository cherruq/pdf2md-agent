# =============================================================================
# pdf2md-agent — environment configuration
# =============================================================================
# Copy this file to `.env`, then fill in your values. CLI flags override the
# env values for a single invocation. See README.md → Configuration for the
# full reference; this file documents every supported `PDF2MD_AGENT_*` knob.

# -----------------------------------------------------------------------------
# Credentials and endpoint
# -----------------------------------------------------------------------------

# OpenAI-compatible endpoint used by the vision pipeline.
# Override to point at any other vision API (MiniMax-M3 default is shown).
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# API key for the endpoint above. Required. Keep this secret; do not commit.
OPENAI_API_KEY=your-api-key-here

# Vision model name to send in the request. Must be served by OPENAI_BASE_URL.
PDF2MD_AGENT_MODEL=MiniMax-M3

# -----------------------------------------------------------------------------
# Token-budget / image-downscale
# -----------------------------------------------------------------------------

# Context-window token limit the runner budgets against.
PDF2MD_AGENT_CTX_LIMIT=2013

# Fraction of ctx_limit the planner will spend per call (0 < safety < 1).
PDF2MD_AGENT_TOKEN_BUDGET_SAFETY=0.85

# Long-side pixel cap for inlined page JPEGs. Lower ⇒ smaller payloads, worse OCR.
PDF2MD_AGENT_IMAGE_LONG_SIDE=1536

# Lower bound for the binary search — never resize below this.
PDF2MD_AGENT_IMAGE_MIN_LONG_SIDE=768

# JPEG quality (1–95) used by the in-memory downscaler.
PDF2MD_AGENT_IMAGE_JPEG_QUALITY=85

# Maximum running-summary size fed into the next extractor.
PDF2MD_AGENT_MAX_SUMMARY_CHARS=800

# -----------------------------------------------------------------------------
# LLM retry / fallback
# -----------------------------------------------------------------------------

# Total LLM call attempts per page (initial + retries).
PDF2MD_AGENT_MAX_RETRIES=4

# Initial retry delay in seconds.
PDF2MD_AGENT_RETRY_INITIAL_DELAY=1.0

# Exponential backoff multiplier between retries.
PDF2MD_AGENT_RETRY_BACKOFF=2.0

# Per-attempt delay cap in seconds.
PDF2MD_AGENT_RETRY_MAX_DELAY=30.0

# Jitter ratio in [0.0, 1.0].
PDF2MD_AGENT_RETRY_JITTER=0.25

# If `true`, fall back to the PDF's native text layer on retry exhaustion;
# if `false`, raise.
PDF2MD_AGENT_FALLBACK_TO_TEXT=true
